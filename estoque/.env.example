# Use DB_DSN to pass the complete PostgreSQL DSN in one variable.
DB_DSN=host=localhost user=postgres password=SUA_SENHA dbname=estoque port=5432 sslmode=disable

# Alternatively set these individual values:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=SUA_SENHA
DB_NAME=estoque

PORT=8080
